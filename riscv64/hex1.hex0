03 45 01 00                                      # a0 = label char
13 01 01 01                                      # restore
13 15 35 00                                      # a0 = char * 8
33 85 AD 00                                      # a0 = &table[char]
03 35 05 00                                      # a0 = target address
33 05 A5 41                                      # a0 = target - IP (relative offset)
13 01 01 FF                                      # reserve 16
23 20 A1 00                                      # buf = 4-byte offset (LE)
93 02 40 00                                      # t0 = 4
23 34 51 00                                      # size = 4
13 85 0A 00                                      # a0 = fout
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
83 B2 8A 02                                      # t0 = fout->write
E7 80 02 00                                      # call write
13 01 01 01                                      # restore
6F F0 5F ED                                      # j second_pass
