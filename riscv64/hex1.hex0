# --- AllocatePool(2KB) for label table ----------------------------
# 256 ASCII chars x 8 bytes/IP = 2048 bytes. Indexed directly by
# the byte following `:`/`%`. The 1-then-shift idiom (li 1; sll
# by 11) is how we get 2048 in two RV64I ops without the heavy
# li-pseudoinstruction expansion.
13 05 20 00                                      # a0 = EFI_LOADER_DATA
93 05 10 00                                      # a1 = 1
93 95 B5 00                                      # a1 = 2048
13 01 01 FF                                      # reserve 16
13 06 01 00                                      # a2 = &pool
83 32 09 04                                      # t0 = boot->allocate_pool
E7 80 02 00                                      # call allocate_pool
83 3D 01 00                                      # s11 = label table
13 01 01 01                                      # restore
# === Pass 1: scan input, populate label table =======================
# Per-byte read loop. On `:` we run :store_label_p1 (record
# table[next_byte] = IP). On `%` we run :skip_pointer_p1 (advance
# IP by 4 since pass 2 will emit 4 bytes here, but skip the
# pointer's label byte). Hex digits accumulate into IP via the
# toggle (s7) and nibble (s8) state.
93 0B F0 FF                                      # s7 = -1 (toggle)
13 0C 00 00                                      # s8 = 0 (hex accum)
13 0D 00 00                                      # s10 = 0 (IP)
13 05 0A 00                                      # a0 = fin
13 01 01 FF                                      # reserve 16
93 02 10 00
23 34 51 00                                      # size = 1
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
23 30 01 00                                      # buf = 0
83 32 0A 02                                      # t0 = fin->read
E7 80 02 00                                      # call read
83 32 81 00                                      # t0 = bytes_read
03 45 01 00                                      # a0 = byte
13 01 01 01                                      # restore
63 8E 02 08                                      # beq EOF -> first_pass_done
93 02 A0 03                                      # t0 = ':'
63 04 55 02                                      # beq -> store_label_p1
93 02 50 02                                      # t0 = '%'
63 0E 55 04                                      # beq -> skip_pointer_p1
EF 00 40 1D                                      # jal ra, hex_func
E3 4C 05 FA                                      # blt → first_pass
# --- nibble toggle: count complete pairs only ---------------------
# IP advances by 1 per *byte*, i.e. per *pair* of nibbles. So
# only increment IP when we have the second nibble. The
# `s7 = -1 - s7` idiom flips the toggle between -1 and 0
# without a branch.
63 D4 0B 00                                      # bge s7, 0 -> fp_toggle
13 0D 1D 00                                      # IP++
93 02 F0 FF                                      # t0 = -1
B3 8B 72 41                                      # s7 = -1 - s7 (flip: -1<->0)
6F F0 5F FA                                      # j first_pass
13 05 0A 00                                      # a0 = fin
13 01 01 FF                                      # reserve 16
93 02 10 00
23 34 51 00                                      # size = 1
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
23 30 01 00                                      # buf = 0
83 32 0A 02                                      # t0 = fin->read
E7 80 02 00                                      # call read
# --- :store_label_p1 -- table[label_char] = current IP -----------
# Read one more byte (the label name), index the 8-byte slot in
# s11 (the label table) by char*8, and store IP there.
03 45 01 00                                      # a0 = label char
13 01 01 01                                      # restore
13 15 35 00                                      # a0 = char * 8
33 85 AD 00                                      # a0 = &table[char]
23 30 A5 01                                      # table[char] = IP
6F F0 9F F6                                      # j first_pass
13 05 0A 00                                      # a0 = fin
13 01 01 FF                                      # reserve 16
93 02 10 00
23 34 51 00                                      # size = 1
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
23 30 01 00                                      # buf = 0
83 32 0A 02                                      # t0 = fin->read
E7 80 02 00                                      # call read
# --- :skip_pointer_p1 -- consume pointer label, IP += 4 ----------
# Pointer reference takes 4 bytes in pass 2's output, so IP must
# skip past those bytes here (we don't actually read them in
# pass 1 -- we just consume the single label-char byte and bump
# IP by 4).
13 01 01 01                                      # restore
13 0D 4D 00                                      # IP += 4
6F F0 9F F3                                      # j first_pass
# === :first_pass_done -- rewind input, start pass 2 =================
# fin->set_position(0) seeks back to the start of the file so
# pass 2 can re-read and emit. State is reset (toggle, accumulator,
# IP) just like pass 1.
13 05 0A 00                                      # a0 = fin
93 05 00 00                                      # a1 = 0 (offset)
83 32 8A 03                                      # t0 = fin->set_position
E7 80 02 00                                      # call set_position(0)
93 0B F0 FF                                      # s7 = -1 (toggle)
13 0C 00 00                                      # s8 = 0
13 0D 00 00                                      # s10 = 0 (IP)
13 05 0A 00                                      # a0 = fin
13 01 01 FF                                      # reserve 16
93 02 10 00
23 34 51 00                                      # size = 1
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
23 30 01 00                                      # buf = 0
83 32 0A 02                                      # t0 = fin->read
E7 80 02 00                                      # call read
83 32 81 00                                      # t0 = bytes_read
03 45 01 00                                      # a0 = byte
13 01 01 01                                      # restore
# === Pass 2: emit bytes (and resolved offsets) =====================
