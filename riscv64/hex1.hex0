93 02 A0 03                                      # t0 = ':'
63 00 55 06                                      # beq -> drop_label_p2 (no emit)
93 02 50 02                                      # t0 = '%'
63 02 55 08                                      # beq -> store_pointer_p2 (4-byte offset)
EF 00 C0 0E                                      # jal ra, hex_func
