03 BB 8C 01                                      # s6 = root_device = image->device
03 B3 8C 03                                      # t1 = image->load_options
83 A3 0C 03                                      # t2 = load_options_size
B3 03 73 00                                      # t2 = end
13 0D 00 00                                      # s10 = 0
93 0D 00 00                                      # s11 = 0
63 82 63 02                                      # beq t2, t1, loop_options_done
93 83 E3 FF                                      # t2 -= 2
03 CE 03 00                                      # t3 = *t2
93 0E 00 02                                      # t4 = ' '
E3 18 DE FF                                      # bne, continue
23 80 03 00                                      # null-terminate
93 0D 0D 00                                      # s11 = prev s10
