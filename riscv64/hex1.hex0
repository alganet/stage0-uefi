13 85 09 00                                      # a0 = rootdir
13 01 01 FF                                      # reserve 16
93 05 01 00                                      # a1 = &fin
13 06 0D 00                                      # a2 = input filename
93 06 10 00                                      # a3 = READ
13 07 00 00                                      # a4 = 0
83 B2 89 00                                      # t0 = rootdir->open
E7 80 02 00                                      # call open(input)
03 3A 01 00                                      # s4 = fin
13 01 01 01                                      # restore
13 85 09 00                                      # a0 = rootdir
13 01 01 FF                                      # reserve 16
93 05 01 00                                      # a1 = &fout
