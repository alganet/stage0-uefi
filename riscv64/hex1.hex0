33 65 AC 00                                      # a0 = combined byte
93 0B F0 FF                                      # s7 = -1
13 01 01 FF                                      # reserve 16
23 30 A1 00                                      # buf = byte
93 02 10 00                                      # t0 = 1
23 34 51 00                                      # size = 1
13 85 0A 00                                      # a0 = fout
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
83 B2 8A 02                                      # t0 = fout->write
E7 80 02 00                                      # call write
13 01 01 01                                      # restore
13 0D 1D 00                                      # IP++
6F F0 DF F6                                      # j second_pass
13 05 0A 00                                      # a0 = fin
13 01 01 FF                                      # reserve 16
93 02 10 00
23 34 51 00                                      # size = 1
93 05 81 00                                      # a1 = &size
13 06 01 00                                      # a2 = &buf
23 30 01 00                                      # buf = 0
83 32 0A 02                                      # t0 = fin->read
E7 80 02 00                                      # call read
13 01 01 01                                      # restore
6F F0 1F F4                                      # j second_pass
