93 06 30 00                                      # a3 = READ|WRITE
93 02 10 00                                      # t0 = 1
93 92 F2 03                                      # t0 = 0x8000000000000000
B3 E6 56 00                                      # a3 = CREATE|READ|WRITE
13 07 00 00                                      # a4 = 0
