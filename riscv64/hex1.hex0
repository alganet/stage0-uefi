# ====================================================================
# hex1 for riscv64 UEFI -- single-character labels + relative offsets
# ====================================================================
#
# Algorithm (two-pass over input):
#   Pass 1: compute IP at every label site
#     - read input byte by byte, increment IP by 1 per hex pair
#     - on `:X` (label define): table[X] = current IP
#     - on `%X` (label use):    treat as 4 bytes (advance IP, ignore X)
#   Pass 2: emit
#     - re-read input from offset 0
#     - on `:X` (label define): drop (already recorded)
#     - on `%X` (label use):    emit 4-byte LE relative offset
#                                = table[X] - current IP
#     - on hex pair: emit 1 byte
#
# Why two passes:
#   Forward references. The relative offset for `%X` can refer to a
#   `:X` later in the file, so we must scan once to populate the
#   table, then again to emit.
#
# Label table layout (allocated 2KB pool):
#   table[ascii] = 8 bytes (signed 64-bit IP)
#   indexed directly by the ASCII byte after `:` or `%`. So labels
#   are single-character (any printable byte). Table is not zeroed
#   on alloc; undefined labels emit garbage offsets -- callers
#   must define before use, with the two-pass framing.
#
# Format (hex1):
#   - hex pairs as in hex0
#   - `:X`  one-char label define (zero bytes emitted)
#   - `%X`  one-char label use   (4 bytes emitted = target - IP)
#   - `#`/`;` start a comment to end-of-line
#
# Generated by gen-hex1-rv64.py.
# Total size: 1920 bytes, Code size: 1304 bytes.
#
# Calling convention:
#   s1=ImageHandle, s2=boot_services, s3=rootdir,
#   s4=fin, s5=fout, s6=root_device, s7=toggle (-1/0),
#   s8=accumulated nibble, s9=image, s10=IP, s11=label table

4D 5A                                            # MZ signature
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 # DOS header padding
80 00 00 00                                      # PE header offset = 0x80
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 # padding to PE header
50 45 00 00                                      # PE signature
64 50                                            # Machine: RISC-V 64
01 00                                            # NumberOfSections: 1
00 00 00 00 00 00 00 00 00 00 00 00              # Timestamp, symbols
F0 00                                            # SizeOfOptionalHeader: 0xF0
2E 00                                            # Characteristics
0B 02 00 00                                      # Magic PE32+ + LinkerVersion
18 05 00 00                                      # SizeOfCode [PATCH]
00 00 00 00                                      # SizeOfInitializedData
00 00 00 00                                      # SizeOfUninitializedData
40 02 00 00                                      # AddressOfEntryPoint: 0x240
40 02 00 00                                      # BaseOfCode: 0x240
00 00 00 00 00 00 00 00                          # ImageBase: 0
40 00 00 00                                      # SectionAlignment: 0x40
40 00 00 00                                      # FileAlignment: 0x40
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00  # OS/Image/Subsystem/Win32 versions
80 07 00 00                                      # SizeOfImage [PATCH]
40 02 00 00                                      # SizeOfHeaders: 0x240
00 00 00 00                                      # Checksum
0A 00 00 00                                      # Subsystem: UEFI App + DllChar
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 # Stack/Heap reserve/commit
00 00 00 00                                      # LoaderFlags
10 00 00 00                                      # NumberOfRvaAndSizes: 16
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 # Data directories (all zero)
2E 74 65 78 74 00 00 00                          # Section name: .text
18 05 00 00                                      # VirtualSize [PATCH]
40 02 00 00                                      # VirtualAddress: 0x240
40 05 00 00                                      # SizeOfRawData [PATCH]
40 02 00 00                                      # PointerToRawData: 0x240
00 00 00 00 00 00 00 00 00 00 00 00              # Relocations, Linenumbers, NumberOf
20 00 00 60                                      # Characteristics: CODE|EXECUTE|READ
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 # padding to 0x240
