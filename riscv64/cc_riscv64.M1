; === [11] Global state / GUIDs ====================================
; UEFI globals stashed at fixed labels so any function in the
; compiler can reach them via auipc/addi without parameter passing.
; All 8-byte slots (LE 16 hex digits) are zero-initialized at link
; time and filled by :_start before parsing begins.
;
; LOADED_IMAGE_GUID / SIMPLE_FS_GUID layout: 16 bytes each, with
; data1 (4 LE), data2 (2 LE), data3 (2 LE), data4 (8 BE). Same
; encoding rule as elsewhere in the chain.

:LOADED_IMAGE_GUID
    ; {5B1B31A1-9562-11D2-8E3F-00A0C969723B}
    A1 31 1B 5B 62 95 D2 11 8E 3F 00 A0 C9 69 72 3B
:SIMPLE_FS_GUID
    ; {964E5B22-6459-11D2-8E39-00A0C969723B}
    22 5B 4E 96 59 64 D2 11 8E 39 00 A0 C9 69 72 3B
:_uefi_ih
    ; ImageHandle (passed as a0 at entry)
    00000000 00000000
:_uefi_st
    ; SystemTable (passed as a1 at entry; needed by dbg_char ConOut)
    00000000 00000000
:_uefi_boot
    ; SystemTable->boot_services (vtable for AllocatePool, etc.)
    00000000 00000000
:_uefi_rd
    ; root_device handle (image->device); used to open SimpleFS
    00000000 00000000
:_uefi_rootdir
    ; FS rootdir handle (rootfs->open_volume result)
    00000000 00000000
:_uefi_output_fn
    ; output filename pointer (UCS-2); saved before first UEFI call
    ; because a4 is caller-saved and gets clobbered.
    00000000 00000000
:_uefi_old_sp
    ; UEFI's original sp (saved before we switch to the 64MiB pool
    ; stack); restored by enter_uefi_stack before close_protocol().
    00000000 00000000
:_user_stack
    ; Top of our switched-to stack; used by enter_user_stack /
    ; enter_uefi_stack to bounce between.
    00000000 00000000
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00
00 00 00 00 00 00 00 00 00 00 00
:ELF_end
