# === :express_number -- prefix + value -> RV64 imm-encoded hex =====
# a0 = numeric value, a1 = prefix byte (`!`/`@`/`~`/`%`).
# Allocates a 10-byte hex string buffer. The output starts with '.'
# (or for %, just the constant) and contains hex digits matching
# the RV64 immediate's bit layout for that instruction class:
#   ! (I-type)  -> hi32 mask, low12 << 20
#   @ (S-type)  -> imm[11:5]<<25 | imm[4:0]<<7  (store/branch)
#   ~ (U-type)  -> upper20 << 12 with sign rounding (for AUIPC/LUI)
#   % (raw)     -> hex32 of value (no encoding; emitted directly)
93 0A 05 00                                      # save VALUE
13 05 A0 00                                      # 10 bytes
EF 00 80 25                                      # ->malloc
93 05 05 00                                      # S=result ptr
13 85 0A 00                                      # restore VALUE
93 02 50 02                                      # '%'
63 08 56 02                                      # ->en_const
93 8A 05 00                                      # save S
93 02 E0 02                                      # '.'
23 80 55 00                                      # S[0]='.'
93 85 15 00
93 02 10 02                                      # '!'
63 06 56 02                                      # ->en_I
93 02 00 04                                      # '@'
63 0C 56 02                                      # ->en_S
93 02 E0 07                                      # '~'
63 0A 56 04                                      # ->en_U
6F F0 8F F7                                      # ->Fail
13 15 05 02
13 55 05 02                                      # mask 32 bits
93 8A 05 00                                      # save S
EF F0 5F DD                                      # →hex32l
6F 00 40 06                                      # →en_done
13 15 45 03                                      # extract low 12
13 55 45 03
13 15 45 01                                      # <<20
EF F0 1F DC                                      # →hex32l
6F 00 00 05                                      # →en_done
93 72 F5 01                                      # lo5
93 92 72 00                                      # <<7
13 13 45 03
13 53 43 03                                      # low 12 bits
13 73 03 FE                                      # & 0xFE0 (=-32 signed)
13 13 43 01                                      # <<20
33 E5 62 00                                      # combine
EF F0 DF D9                                      # →hex32l
6F 00 C0 02                                      # →en_done
93 12 45 03
93 D2 42 03                                      # low 12
37 13 00 00                                      # t1=0x1000
13 53 13 00                                      # t1=0x800
B7 F3 FF FF                                      # 0xFFFFF000
33 75 75 00                                      # value & 0xFFFFF000
63 C6 62 00                                      # →en_U_ok
B7 13 00 00                                      # 0x1000
3B 05 75 00                                      # + 0x1000
EF F0 1F D7                                      # →hex32l
23 80 05 00                                      # null-terminate hex string
13 85 0A 00                                      # return S
