# === ~name : U-type encoding =======================================
# Used by AUIPC: hi20 = (disp + 0x800) >> 12, placed in bits 12-31.
# The +0x800 rounds for the matching ADDI's signed lo12 below.
# After computation, place hi20 << 12 into shift_reg so it XORs
# into the next 4 emitted bytes.
13 01 01 FF
23 30 11 00
EF F0 1F E1                                      # call store_pointer
33 0E A5 41                                      # t3 = target - IP (displacement)
93 0E F0 7F                                      # t4 = 0x7FF
93 8E 1E 00                                      # t4 = 0x800
33 0E DE 01                                      # t3 = disp + 0x800
13 5E CE 40                                      # t3 >>= 12
13 1E CE 00                                      # t3 = hi20 << 12 (U-type XOR)
B3 C4 C4 01                                      # s1 ^= encoded
83 30 01 00
