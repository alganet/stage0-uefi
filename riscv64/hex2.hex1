# === :fgetc -- in-memory byte reader from buf_start..buf_end =======
# We loaded the whole input file into memory; fgetc here just
# advances s4 (in pass 1) or s4 again (rewound for pass 2).
# Returns -1 in a0 on EOF (s4 >= buf_end).
97 02 00 00                                      # auipc t0, %hi(buf_end_data)
93 82 C2 05                                      # addi t0, t0, %lo(buf_end_data)
83 B2 02 00                                      # t0=buf_end
