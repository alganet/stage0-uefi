# Initialize per-pass state, then per-byte loop:
#   :name  -> :store_label  (record HEAD entry, IP unchanged)
#   ~/!/@/$ -> :fp_shift_op (consume name + 4 bytes raw, IP+=4)
#   %name  -> :fp_pointer   (IP+=4, %name>base also possible)
#   &name  -> :fp_pointer   (also IP+=4)
#   .name  -> :fp_dot       (IP+=4)
#   hex    -> nibble accumulator + IP++ on second nibble
#   #/;    -> :purge_comment via hex_func returning sentinel
