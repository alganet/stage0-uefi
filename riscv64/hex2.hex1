93 02 A0 00                                      # LF
E3 18 55 FE                                      # →pc_loop
83 30 01 00
13 01 01 01
13 05 F0 FF
67 80 00 00
# === :done -- write output buffer to file, close everything ========
# Pass 2 left out_pos (s4) past the last emitted byte and out_start
# was saved earlier. fout->Write(out_start, out_size) flushes the
# whole linked image in a single call, then Flush ensures FAT
# durability before close (some EDK2 builds drop unflushed writes
# at protocol close).
97 02 00 00                                      # auipc t0, %hi(out_start_data)
93 82 C2 14                                      # addi t0, t0, %lo(out_start_data)
03 B3 02 00                                      # t1=out_start
B3 03 64 40                                      # t2=out_size (includes trailer)
13 01 01 FF
23 30 71 00                                      # size on stack
23 34 61 00                                      # save out_start
13 85 0A 00                                      # fout
93 05 01 00                                      # &size
03 36 81 00                                      # buffer=out_start
83 B2 8A 02                                      # fout->Write
E7 80 02 00                                      # write all
13 01 01 01
13 85 0A 00
83 B2 0A 05                                      # Flush
E7 80 02 00                                      # flush
13 85 0C 00
83 32 89 04
E7 80 02 00                                      # free_pool
13 85 0A 00
83 B2 0A 01
E7 80 02 00                                      # close fout
13 85 09 00
83 B2 09 01
E7 80 02 00                                      # close rootdir
17 03 00 00                                      # auipc t1, %hi(image_handle_data)
13 03 03 0F                                      # addi t1, t1, %lo(image_handle_data)
83 34 03 00                                      # s1=ImageHandle (restored)
13 05 0B 00
