83 32 81 01                                      # t0 = actual file_size
13 01 01 11
17 13 00 00                                      # auipc t1, %hi(file_size_data)
13 03 43 8D                                      # addi t1, t1, %lo(file_size_data)
23 30 53 00                                      # save file_size to data label
